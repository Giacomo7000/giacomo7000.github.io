---
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/Button.astro";
import SectionHeading from "@components/SectionHeading.astro";
import ProjectCard from "@components/ProjectCard.astro";
import ArchiveCard from "@components/ArchiveCard.astro";
import GMLogo from "@components/GMLogo.astro";
import { site } from "@data/site";
import { getFeaturedProjects, getArchiveEntries } from "@lib/content";
import { t, localizedPath } from "@lib/i18n";

const lang = "en";
const projects = await getFeaturedProjects();
const archive = (await getArchiveEntries()).slice(0, 3);
---

<BaseLayout lang={lang} title="AI Developer" path="/">
  <section class="hero container">
    <div class="hero-copy reveal">
      <p class="eyebrow">AI Developer and Technical Analyst</p>
      <h1>Giacomo Mariuzza</h1>
      <p class="lead">I operate on AI solutions applied to real-world problems, combining development, client understanding, and an interest in concrete machine-learning systems while completing a Master’s degree in AI & Cybersecurity.</p>
      <div class="button-row">
        <Button href="/projects">{t(lang, "viewProjects")}</Button>
        <Button href="/contact" variant="secondary">{t(lang, "contactMe")}</Button>
        <Button href={site.cvPath[lang]} variant="secondary">{t(lang, "viewCv")}</Button>
      </div>
    </div>
    <div class="hero-mark reveal" aria-hidden="true">
      <GMLogo size={260} />
    </div>
  </section>
  <section class="section">
    <div class="container split">
      <SectionHeading eyebrow="About" title="AI, software, and real-world problems." lead="Between AI, software, and cybersecurity, I learn by putting things to the test: small prototypes, automations, local models, and practical tools. I work on applied AI solutions, but what interests me most is the transition from idea, to experiment, to real use." />
      <Button href="/about" variant="secondary">Read about me</Button>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <SectionHeading eyebrow="Projects" title={t(lang, "featuredProjects")} lead="A selection of projects that show how I work: from idea to prototype, through to real and usable solutions." />
      <div class="grid grid-3">
        {projects.map((project) => (
          <ProjectCard
            project={project}
            lang={lang}
            descriptionField={project.slug === "bachelor-thesis-instagram-engagement" ? "subtitle" : "summary"}
          />
        ))}
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <SectionHeading eyebrow="Events" title={t(lang, "latestArchive")} lead="Notes, experiences, and moments that mark my path through the world of technology." />
      <div class="grid grid-3">
        {archive.map((entry) => <ArchiveCard entry={entry} lang={lang} />)}
      </div>
    </div>
  </section>
  <section class="section contact-band">
    <div class="container split">
      <SectionHeading eyebrow="Contact" title="If you want to talk about AI, professional collaborations, or a project to build, feel free to write me." />
      <Button href={localizedPath(lang, "/contact")}>{t(lang, "contactMe")}</Button>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 38%);
    align-items: center;
    gap: clamp(34px, 7vw, 80px);
    min-height: calc(100vh - 70px);
    padding: 72px 0;
  }

  .hero-copy {
    display: grid;
    gap: 24px;
  }

  .hero-mark {
    position: relative;
    display: grid;
    place-items: center;
    aspect-ratio: 1;
    border: 1px solid var(--line);
    border-radius: 34px;
    background: color-mix(in srgb, var(--surface) 88%, transparent);
    overflow: hidden;
  }

  .hero-mark :global(.gm-logo) {
    width: min(68%, 280px);
    height: auto;
    aspect-ratio: 1;
  }

  .split {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
  }

  .contact-band {
    background: color-mix(in srgb, var(--surface) 58%, transparent);
  }

  @media (max-width: 860px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
      padding: 56px 0;
    }

    .hero-mark {
      max-width: 420px;
    }

    .split {
      display: grid;
      align-items: start;
    }
  }
</style>
