---
import BaseLayout from "@layouts/BaseLayout.astro";
import SectionHeading from "@components/SectionHeading.astro";
import Timeline from "@components/Timeline.astro";
import { t } from "@lib/i18n";

const lang = "en";
---

<BaseLayout lang={lang} title="About" path="/about" description="About Giacomo Mariuzza, AI Developer and Technical Analyst studying AI & Cybersecurity.">
  <section class="page-hero container reveal">
    <p class="eyebrow">About</p>
    <h1>I started by loving technology. I kept going by building it.</h1>
    <p class="lead">I am Giacomo Mariuzza. My interest in computer science was shaped early by Apple’s way of combining technology, design, and user experience. After a bachelor’s degree in IoT, Big Data and Machine Learning, I became especially interested in neural networks and AI systems.</p>
  </section>
  <section class="section">
    <div class="container two-col">
      <div class="prose reveal">
        <p>I am now pursuing a master’s degree in AI & Cybersecurity, a double degree with the University of Klagenfurt, which lets me specialize across artificial intelligence and cybersecurity.</p>
        <p>Alongside university, I work at Aipertech, a startup that brings AI into companies. I started from a more commercial and client-facing position because I enjoy understanding needs, discussing feasible solutions, and guiding implementation ideas. Over time, the work became a mix of client-facing strategy and hands-on programming, which fits how I like to work.</p>
      </div>
      <div>
        <h2>{t(lang, "timeline")}</h2>
        <Timeline lang={lang} />
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <SectionHeading eyebrow="Practice" title={t(lang, "howIWork")} lead="I am not only interested in imagining solutions: I like getting hands-on, testing them, understanding their limits, and turning them into something useful." />
      <div class="grid grid-3">
        <div class="mini card reveal"><h3>Clarity</h3><p>Translate unclear needs into concrete requirements, constraints, and next steps.</p></div>
        <div class="mini card reveal"><h3>Concreteness</h3><p>I like turning ideas and technologies into something real: a demo, a prototype, a tool that can be tested and improved.</p></div>
        <div class="mini card reveal"><h3>Curiosity</h3><p>Keep learning across AI, software, cybersecurity, design, and real business use cases.</p></div>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container grid grid-3">
      <div class="mini card reveal"><h3>{t(lang, "education")}</h3><p>Bachelor in IoT, Big Data and Machine Learning. Master in AI & Cybersecurity in progress, double degree with University of Klagenfurt.</p></div>
      <div class="mini card reveal"><h3>{t(lang, "currentWork")}</h3><p>AI applied to companies at Aipertech, combining technical analysis, client work, and development.</p></div>
      <div class="mini card reveal"><h3>{t(lang, "interests")}</h3><p>I am interested in applied AI, AI agents, local LLMs, and cybersecurity, especially when they become product-oriented software, minimal iOS interfaces, and design-conscious solutions.</p></div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    display: grid;
    gap: 20px;
    padding: 82px 0 64px;
  }

  .page-hero h1 {
    max-width: 980px;
    font-size: clamp(2.7rem, 6vw, 5.8rem);
  }

  .two-col {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 0.7fr);
    gap: clamp(34px, 6vw, 74px);
  }

  .prose {
    display: grid;
    gap: 18px;
    color: var(--muted);
    font-size: 1.1rem;
  }

  .mini {
    display: grid;
    gap: 10px;
    padding: 20px;
    box-shadow: none;
  }

  .mini p {
    color: var(--muted);
  }

  @media (max-width: 860px) {
    .two-col {
      grid-template-columns: 1fr;
    }
  }
</style>
