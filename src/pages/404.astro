---
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/Button.astro";
import { t } from "@lib/i18n";

const lang = "en";
---

<BaseLayout lang={lang} title="404" path="/404">
  <section class="not-found container reveal">
    <p class="eyebrow">404</p>
    <h1>{t(lang, "notFound")}</h1>
    <p class="lead">{t(lang, "notFoundText")}</p>
    <Button href="/">{t(lang, "goHome")}</Button>
  </section>
</BaseLayout>

<style>
  .not-found {
    display: grid;
    gap: 18px;
    align-content: center;
    min-height: 70vh;
  }
</style>
