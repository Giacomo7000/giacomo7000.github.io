---
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { site, type Lang } from "@data/site";
import "../styles/global.css";

const {
  lang = "en",
  title = site.name,
  description = "AI Developer building practical systems at the intersection of artificial intelligence, software, and business needs.",
  path = Astro.url.pathname,
  image = "/og-image.svg"
} = Astro.props as {
  lang?: Lang;
  title?: string;
  description?: string;
  path?: string;
  image?: string;
};

const pageTitle = title === site.name ? title : `${title} | ${site.name}`;
const canonical = new URL(path, site.url).toString();
const imageUrl = new URL(image, site.url).toString();
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
const umamiId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
const umamiScript = import.meta.env.PUBLIC_UMAMI_SCRIPT_URL;
---

<!doctype html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon/favicon-light.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon/favicon-light.png" type="image/png" />
    <link rel="apple-touch-icon" href="/favicon/favicon-light.png" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <script is:inline>
      const savedTheme = localStorage.getItem("theme");
      const systemTheme = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
      const initialTheme = savedTheme === "dark" || savedTheme === "light" ? savedTheme : systemTheme;
      document.documentElement.dataset.theme = initialTheme;
    </script>
    {plausibleDomain && <script defer data-domain={plausibleDomain} src="https://plausible.io/js/script.js"></script>}
    {umamiId && umamiScript && <script defer src={umamiScript} data-website-id={umamiId}></script>}
  </head>
  <body>
    <Header lang={lang} path={path} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
    <script is:inline>
      const setFavicon = (theme) => {
        const icon = document.querySelector('link[rel="icon"]');
        const pngIcon = document.querySelector('link[rel="alternate icon"]');
        const appleIcon = document.querySelector('link[rel="apple-touch-icon"]');
        const iconHref = theme === "dark" ? "/favicon/favicon-dark.svg" : "/favicon/favicon-light.svg";
        const pngHref = theme === "dark" ? "/favicon/favicon-dark.png" : "/favicon/favicon-light.png";
        icon?.setAttribute("href", iconHref);
        pngIcon?.setAttribute("href", pngHref);
        appleIcon?.setAttribute("href", pngHref);
      };

      const toggle = document.querySelector("[data-theme-toggle]");
      setFavicon(document.documentElement.dataset.theme);
      toggle?.addEventListener("click", () => {
        const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        localStorage.setItem("theme", next);
        setFavicon(next);
      });

      const observer = "IntersectionObserver" in window && new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12 });
      document.querySelectorAll(".reveal").forEach((el) => observer ? observer.observe(el) : el.classList.add("is-visible"));
    </script>
  </body>
</html>
