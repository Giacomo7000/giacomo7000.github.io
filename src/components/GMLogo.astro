---
const { size = 34 } = Astro.props;
---

<span class="gm-logo" style={`--logo-size: ${size}px`} aria-label="GM monogram" role="img">
  <img src="/assets/brand/gm-monogram.png" alt="" loading="eager" />
</span>

<style>
  .gm-logo {
    display: inline-grid;
    width: var(--logo-size);
    height: var(--logo-size);
    flex: 0 0 auto;
  }

  .gm-logo img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }
</style>
