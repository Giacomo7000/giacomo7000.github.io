---
const { eyebrow, title, lead } = Astro.props;
---

<div class="section-heading reveal">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  {lead && <p class="lead">{lead}</p>}
</div>

<style>
  .section-heading {
    display: grid;
    gap: 16px;
    max-width: 830px;
    margin-bottom: 34px;
  }
</style>
