---
const label = Astro.props.label || "Theme";
---

<button class="icon-button" type="button" data-theme-toggle aria-label={label} title={label}>
  <svg viewBox="0 0 24 24" aria-hidden="true">
    <path d="M12 3.2v2.2M12 18.6v2.2M5.8 5.8l1.6 1.6M16.6 16.6l1.6 1.6M3.2 12h2.2M18.6 12h2.2M5.8 18.2l1.6-1.6M16.6 7.4l1.6-1.6" />
    <circle cx="12" cy="12" r="3.7" />
  </svg>
</button>

<style>
  .icon-button {
    display: inline-grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: color-mix(in srgb, var(--surface) 82%, transparent);
    color: var(--text);
    cursor: pointer;
    transition: background var(--transition), transform var(--transition);
  }

  .icon-button:hover {
    transform: translateY(-1px);
    background: var(--surface-strong);
  }

  svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
  }
</style>
