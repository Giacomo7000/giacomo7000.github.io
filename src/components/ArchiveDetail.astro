---
import type { CollectionEntry } from "astro:content";
import type { Lang } from "@data/site";
import { localize, localizedPath, t } from "@lib/i18n";
import { formatArchiveDate } from "@lib/dates";

const { entry, lang } = Astro.props as { entry: CollectionEntry<"archive">; lang: Lang };
const displayDate = formatArchiveDate(entry.data, lang);
const sectionParagraphs = (body: string) => body.split(/\n\s*\n/).map((paragraph) => paragraph.trim()).filter(Boolean);
---

<article class="detail container">
  <a class="back-link" href={localizedPath(lang, "/archive")}>{t(lang, "backArchive")}</a>
  <header class="detail-hero reveal">
    <p class="eyebrow">
      <time datetime={entry.data.date}>{displayDate}</time>
      {entry.data.location && <> · {entry.data.location}</>}
    </p>
    <h1>{localize(entry.data.title, lang)}</h1>
    <p class="lead">{localize(entry.data.summary, lang)}</p>
    {entry.data.cover && <img src={entry.data.cover} alt="" loading="eager" />}
  </header>
  <section class="detail-body">
    {entry.data.sections.map((section) => (
      <div class="content-block reveal">
        <h2>{localize(section.title, lang)}</h2>
        {sectionParagraphs(localize(section.body, lang)).map((paragraph) => <p>{paragraph}</p>)}
      </div>
    ))}
  </section>
  {entry.data.gallery.length > 1 && (
    <section class="gallery reveal" aria-label="Gallery">
      {entry.data.gallery.map((image) => <img src={image} alt="" loading="lazy" />)}
    </section>
  )}
  {entry.data.links.length > 0 && (
    <section class="content-block reveal">
      <div class="button-row">
        {entry.data.links.map((link) => (
          <a class="button" href={link.url} target="_blank" rel="noreferrer">{localize(link.label, lang)}</a>
        ))}
      </div>
    </section>
  )}
</article>

<style>
  .detail {
    padding: 42px 0 96px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 34px;
    color: var(--muted);
    font-weight: 800;
  }

  .detail-hero {
    display: grid;
    gap: 20px;
    max-width: 940px;
  }

  .detail-hero h1 {
    font-size: clamp(2.8rem, 7vw, 6.2rem);
  }

  .detail-hero img {
    width: 100%;
    max-height: 560px;
    object-fit: cover;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--surface);
    margin-top: 14px;
  }

  .detail-body {
    display: grid;
    gap: 34px;
    max-width: 820px;
    margin-top: 44px;
  }

  .content-block {
    display: grid;
    gap: 12px;
  }

  .content-block h2 {
    font-family: var(--font-sans);
    font-size: 1.4rem;
  }

  .content-block p {
    color: var(--muted);
    font-size: 1.05rem;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 48px;
  }

  .gallery img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  @media (max-width: 760px) {
    .gallery {
      grid-template-columns: 1fr;
    }
  }
</style>
