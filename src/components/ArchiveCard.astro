---
import type { CollectionEntry } from "astro:content";
import type { Lang } from "@data/site";
import { localize, localizedPath, t } from "@lib/i18n";
import { formatArchiveDate } from "@lib/dates";

const { entry, lang } = Astro.props as { entry: CollectionEntry<"archive">; lang: Lang };
const href = localizedPath(lang, `/archive/${entry.slug}`);
const displayDate = formatArchiveDate(entry.data, lang);
---

<article class="archive-card card reveal">
  {entry.data.cover && (
    <a class="cover" href={href} aria-label={localize(entry.data.title, lang)}>
      <img src={entry.data.cover} alt="" loading="lazy" />
    </a>
  )}
  <div class="card-body">
    <div class="meta">
      <time datetime={entry.data.date}>{displayDate}</time>
      {entry.data.location && <span>{entry.data.location}</span>}
    </div>
    <h3><a href={href}>{localize(entry.data.title, lang)}</a></h3>
    <p>{localize(entry.data.summary, lang)}</p>
    <a class="text-link" href={href}>{t(lang, "readMore")}</a>
  </div>
</article>

<style>
  .archive-card {
    overflow: hidden;
  }

  .cover {
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--surface-strong);
  }

  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-body {
    display: grid;
    gap: 13px;
    padding: 20px;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  p {
    color: var(--muted);
  }

  .text-link {
    width: fit-content;
    color: var(--accent);
    font-weight: 800;
  }
</style>
