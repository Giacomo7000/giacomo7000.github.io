---
import GMLogo from "./GMLogo.astro";
import { site } from "@data/site";
import type { Lang } from "@data/site";

const { lang } = Astro.props as { lang: Lang };
const cvHref = site.cvPath[lang];
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <GMLogo size={30} />
      <span>{site.name}</span>
    </div>
    <p>{lang === "en" ? "AI projects, technical analysis, and thoughtful software." : "Progetti AI, analisi tecnica e software curato."}</p>
    <div class="footer-links">
      <a class="footer-icon-link" href={`mailto:${site.email}`} aria-label="Email">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M4 6h16v12H4z"></path>
          <path d="m4 7 8 6 8-6"></path>
        </svg>
        <span>Email</span>
      </a>
      <a class="footer-icon-link" href={site.linkedin} target="_blank" rel="noreferrer" aria-label="LinkedIn">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M4 10v10"></path>
          <path d="M4 4.5v.01"></path>
          <path d="M10 20v-6.2c0-2.1 1.2-3.4 3-3.4s3 1.3 3 3.4V20"></path>
          <path d="M10 10v10"></path>
          <path d="M20 20v-6.8c0-4.1-2.2-6.2-5.2-6.2-2 0-3.3 1-4 2"></path>
        </svg>
        <span>LinkedIn</span>
      </a>
      <a href={cvHref}>CV</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--line);
    padding: 34px 0;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 20px;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .footer-brand,
  .footer-links {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .footer-brand {
    color: var(--text);
    font-weight: 800;
  }

  .footer-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 750;
  }

  .footer-icon-link svg {
    width: 1rem;
    height: 1rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @media (max-width: 820px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
