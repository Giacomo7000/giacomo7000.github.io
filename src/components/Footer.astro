---
import GMLogo from "./GMLogo.astro";
import { site } from "@data/site";
import type { Lang } from "@data/site";

const { lang } = Astro.props as { lang: Lang };
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <GMLogo size={30} />
      <span>{site.name}</span>
    </div>
    <p>{lang === "en" ? "AI projects, technical analysis, and thoughtful software." : "Progetti AI, analisi tecnica e software curato."}</p>
    <div class="footer-links">
      <a href={`mailto:${site.email}`}>Email</a>
      <a href={site.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
      <a class="footer-icon-link" href={site.github} target="_blank" rel="noreferrer" aria-label="GitHub">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.44 5.44 0 0 0 3.5 8.55c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
        </svg>
        <span>GitHub</span>
      </a>
      <a href={site.cvPath}>CV</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--line);
    padding: 34px 0;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 20px;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .footer-brand,
  .footer-links {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .footer-brand {
    color: var(--text);
    font-weight: 800;
  }

  .footer-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 750;
  }

  .footer-icon-link svg {
    width: 1rem;
    height: 1rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @media (max-width: 820px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
